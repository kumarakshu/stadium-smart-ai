{
    "env": {
        "browser": true,
        "es2021": true,
        "jest": true,
        "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": 13,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": "error",
        "no-console": "off",
        "semi": ["error", "always"],
        "quotes": ["error", "single", { "avoidEscape": true, "allowTemplateLiterals": true }]
    },
    "globals": {
        "CONFIG": "readonly",
        "lucide": "readonly",
        "StadiumOffsets": "readonly",
        "google": "readonly",
        "StadiumMap": "readonly"
    }
}
